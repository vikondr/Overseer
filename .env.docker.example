# Docker environment variables
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env to version control

# ── Google OAuth2 ────────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must include: http://localhost/login/oauth2/code/google
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# ── JWT ──────────────────────────────────────────────────────
# Must be at least 32 random characters
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
# JWT_EXPIRATION_MS=86400000

# ── Frontend URL ─────────────────────────────────────────────
# Where the frontend is accessible from the browser.
# Used for the OAuth2 post-login redirect back to /auth/callback.
# Change to your domain/IP if deploying remotely.
FRONTEND_URL=http://localhost
